<table>
<thead><tr><th>Action</th><th>Key</th></tr></thead>
<tbody>
<tr><td>Move</td><td>WASD</td></tr>
<tr><td>Jump</td><td>Spacebar</td></tr>
<tr><td>Crouch</td><td>Shift / Ctrl</td></tr>
<tr><td>Shoot</td><td>Left Mouse Click</td></tr>
<tr><td>Aim / Zoom</td><td>Right Mouse Click</td></tr>
